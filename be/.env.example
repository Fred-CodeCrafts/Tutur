# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bahasa_daerah?sslmode=disable

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRY_HOURS=24

# S3-Compatible Storage (Cloudflare R2 / MinIO / Supabase)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=bahasa-daerah
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# AI API
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=your-ai-api-key-here

# Server
PORT=8080
